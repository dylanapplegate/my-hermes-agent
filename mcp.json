{
    "mcpServers": {
        "firecrawl-mcp": {
            "command": "npx",
            "args": [
                "-y",
                "firecrawl-mcp"
            ],
            "env": {
                "FIRECRAWL_API_URL": "http://localhost:3002",
                "FIRECRAWL_API_KEY": "not-needed-locally"
            }
        },
        "docker": {
            "command": "npx",
            "args": [
                "-y",
                "mcp-server-docker"
            ],
            "env": {
                "DOCKER_HOST": "unix:///var/run/docker.sock"
            }
        }
    }
}